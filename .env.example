# Database Configuration
DATABASE_URL=postgresql+asyncpg://vocabu_user:vocabu_password@localhost:5435/vocabu_speech_db
DATABASE_ECHO=false

# Redis Configuration  
REDIS_URL=redis://localhost:6382
REDIS_DECODE_RESPONSES=true

# FastAPI Configuration
ENVIRONMENT=development
DEBUG=true
APP_NAME=VocabuRex Speech Service
APP_VERSION=1.0.0
PORT=3005
HOST=0.0.0.0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload Configuration
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
ALLOWED_AUDIO_FORMATS=wav,mp3,m4a,flac,ogg

# Speech Recognition Configuration
# Local Whisper Model
WHISPER_MODEL=base  # tiny, base, small, medium, large, large-v2, large-v3
WHISPER_MODEL_PATH=./models/whisper  # Local model cache directory
WHISPER_DEVICE=cpu  # cpu, cuda, auto
WHISPER_COMPUTE_TYPE=int8  # int8, int16, float16, float32

# Google Cloud Speech (Optional)
GOOGLE_CLOUD_CREDENTIALS_PATH=./credentials/google-speech-credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_SPEECH_ENABLED=false

# Azure Cognitive Services (Optional)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-region
AZURE_SPEECH_ENABLED=false

# Default Speech Engine
DEFAULT_SPEECH_ENGINE=whisper  # whisper, google, azure

# Audio Processing
SAMPLE_RATE=16000
CHUNK_SIZE=1024
AUDIO_FORMAT=wav
NOISE_REDUCTION_ENABLED=true
VOICE_ACTIVITY_DETECTION=true

# Pronunciation Assessment
PRONUNCIATION_THRESHOLD=0.7
SIMILARITY_THRESHOLD=0.8
CONFIDENCE_THRESHOLD=0.6

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=speech_service.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Health Check
HEALTH_CHECK_TIMEOUT=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=300

# Monitoring
METRICS_ENABLED=true
TRACING_ENABLED=false